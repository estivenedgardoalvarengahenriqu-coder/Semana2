Algoritmo Ejercicio5
	Definir num1, num2, num3, suma Como Real
    
    Escribir "Ingrese el primer número:"
    Leer num1
    
    Escribir "Ingrese el segundo número:"
    Leer num2
    
    Escribir "Ingrese el tercer número:"
    Leer num3
    
    suma <- num1 + num2 + num3
    
    Escribir "La suma total es: ", suma
FinAlgoritmo
