Algoritmo Ejercicio1
	Definir num1, num2, suma Como Entero
    
    Escribir "Ingrese el primer número entero:"
    Leer num1
    
    Escribir "Ingrese el segundo número entero:"
    Leer num2
    
    suma <- num1 + num2
    
    Escribir "La suma de ", num1, " y ", num2, " es: ", suma
FinAlgoritmo
